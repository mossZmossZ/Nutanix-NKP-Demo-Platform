  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^26.1.1",
    "@types/ssh2": "^1.15.4",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.13",
    "mongodb-memory-server": "^11.2.0",
    "oxlint": "^1.74.0",
