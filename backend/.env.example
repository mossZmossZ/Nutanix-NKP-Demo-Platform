NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017/nkp-workshop
JWT_SECRET=

# Static admin account, upserted from these values on every boot.
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Key used to derive the AES-256-GCM key for Assignment.rdpPassword encryption (src/lib/crypto.ts)
CREDENTIAL_SECRET=

# guacd (in-browser RDP). Backend runs on the host in dev; guacd is published on localhost:4822.
GUACD_HOST=localhost
GUACD_PORT=4822
# Secret for the short-lived guacamole-lite connection token (server-side only).
GUAC_TOKEN_SECRET=
