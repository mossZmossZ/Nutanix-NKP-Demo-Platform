# Production environment for deploy/docker-compose.prod.yml.
# Copy to deploy/.env and fill every blank. deploy/.env is git-ignored — never commit it.
#
#   cp deploy/.env.prod.example deploy/.env
#
# ─────────────────────────────────────────────────────────────────────────────
#  ⚠  GENERATE-ONCE SECRETS — DO NOT CHANGE AFTER FIRST DEPLOY
#     CREDENTIAL_SECRET derives the AES key that encrypts every stored password
#     (lab-find + RDP creds). If you change it, all existing encrypted values
#     become PERMANENTLY undecryptable. Changing JWT_SECRET logs everyone out.
#     Generate each with:   openssl rand -base64 32
#     The backend refuses to boot in production if any of these is unset/default.
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=
CREDENTIAL_SECRET=
GUAC_TOKEN_SECRET=

# ── Image tag ────────────────────────────────────────────────────────────────
# Which image tag to run. deploy.sh overrides this to pin a specific <git-sha>
# for rollbacks; `latest` follows the newest CI build.
IMAGE_TAG=latest

# ── Public listener ──────────────────────────────────────────────────────────
# Host port the nginx edge binds. Default 80 (HTTP behind a Cloudflare tunnel).
# For direct TLS on the host, see the HTTPS notes in docker-compose.prod.yml.
HTTP_PORT=80
# HTTPS_PORT=443
# TLS_CERT_DIR=./certs        # dir holding fullchain.pem + privkey.pem (HTTPS mode)

# ── Static admin (bootstrap) ─────────────────────────────────────────────────
# Seeded/upserted on every boot. Rotate ADMIN_PASSWORD after first login.
ADMIN_USER=admin
ADMIN_PASSWORD=

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Root credentials for the mongo container; the backend's MONGO_URI is built
# from these (see docker-compose.prod.yml). Password is defined here only.
MONGO_ROOT_USER=nkp
MONGO_ROOT_PASSWORD=
MONGO_DB=nkp

# ── Locale ───────────────────────────────────────────────────────────────────
# IANA timezone defining the "day" boundary for per-user active-time accounting.
WORKSHOP_TZ=Asia/Bangkok
