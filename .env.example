# Backend Server
PORT=3000

# MongoDB
# Connection string for MongoDB. Format: mongodb://username:password@host:port/database
MONGO_URI=mongodb://root:devpassword@localhost:27017/nkp?authSource=admin

# Redis
# Redis connection string for BullMQ job queue
REDIS_URL=redis://localhost:6379

# Authentication
# JWT secret key for signing and verifying JWT tokens (httpOnly cookie)
# Generate with: openssl rand -base64 32
JWT_SECRET=changeme

# Static admin account (seeded on first boot)
# Username for the initial admin account
ADMIN_USER=admin
# Password for the initial admin account (should be changed on first login)
ADMIN_PASSWORD=changeme

# Nutanix Terraform Provider Credentials
# Nutanix Prism Element username for infrastructure provisioning
NUTANIX_USERNAME=changeme
# Nutanix Prism Element password for infrastructure provisioning
NUTANIX_PASSWORD=changeme
# Nutanix Prism Element endpoint URL (e.g. https://10.0.0.1:9440)
NUTANIX_ENDPOINT=https://changeme:9440
# Nutanix cluster port (typically 9440)
NUTANIX_PORT=9440
# Set to true to allow self-signed certificates (dev/lab only)
NUTANIX_INSECURE=false

# Encryption
# App-level encryption key for encrypting sensitive credentials at rest (RDP passwords, etc)
# Generate with: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=changeme

# Key used to derive the AES-256-GCM key for Assignment.rdpPassword encryption (backend/src/lib/crypto.ts)
CREDENTIAL_SECRET=changeme

# Guacamole (lightweight: guacd + in-app WS tunnel, no Java webapp)
# guacd host/port the backend RDP tunnel connects to. In dev, guacd runs in
# docker-compose.dev.yml and publishes 4822 to the host.
GUACD_HOST=localhost
GUACD_PORT=4822
# Secret for the short-lived guacamole-lite connection token (minted + consumed
# server-side in the WS upgrade; never sent to the browser).
GUAC_TOKEN_SECRET=changeme

# Optional: Logging
# Log level: debug, info, warn, error
LOG_LEVEL=info
